###############################################################################
# InferHaven Core — Environment Configuration
#
# Copy this file to .env and customize:
#   cp .env.example .env
#   chmod 600 .env          # API keys live here — keep it owner-only
#
# All values have sensible defaults. The only thing you MUST change for
# production is CODE_SERVER_PASSWORD and adding your AUTHORIZED_KEYS.
#
# SECURITY NOTES
#   - .env values are injected into the workspace container via `env_file:`.
#     Any user with shell in the container (including HAVEN_EXTRA_USERS) can
#     read them via `cat /proc/1/environ`. Don't add anything here that you
#     wouldn't share with every workspace user.
#   - `docker compose config` renders every value plaintext. Do not paste its
#     output into chat / issues / pastebins. For safe diagnostics:
#         docker compose config --format json | jq 'del(.services[].environment)'
#   - `haven up` and `haven doctor` enforce / warn about chmod 600 on this file.
###############################################################################

# ── AI Model Configuration ──────────────────────────────────────────────────
# Default model pulled on first startup. Change to any Ollama-compatible model.
#
# Verify tool-call support after pulling:  haven test-tools <model>
# default model confirmed to work with all supported automatic harnesses: qwen3.5:9b
DEFAULT_MODEL=qwen3.5:9b

# ── Ollama Configuration ────────────────────────────────────────────────────
# Use different images, unless you need a specific one you should most likely
# be using the default ollama/ollama:latest
# AMD RocM specific image: ollama/ollama:rocm
OLLAMA_IMAGE=ollama/ollama:latest

# Default context window size used by all AI harness configs (aider, opencode, etc.)
# when a model does not have num_ctx set via `haven params`. Defaults to 32768.
# Lower this (e.g. 8192) on hardware with limited VRAM.
#OLLAMA_DEFAULT_CTX=32768

# Flash attention — faster inference and lower peak VRAM at large context lengths.
# Enabled by default. Disable only if you see NaN/corrupt outputs on unusual hardware.
#OLLAMA_FLASH_ATTENTION=1

# KV cache quantization — reduces the VRAM used by the KV cache without altering
# model weights or requiring a re-download. Applied server-wide to all models.
#   q8_0 — ~50% less KV cache VRAM, negligible quality impact (default)
#   q4_0 — ~75% less KV cache VRAM, minimal quality impact
#   f16  — full precision (Ollama upstream default, highest VRAM usage)
#
# Quantized KV cache (q8_0 / q4_0) requires OLLAMA_FLASH_ATTENTION=1 (the default).
# Fully GPU-resident on Ampere+ (RTX 30xx/40xx, compute capability >= 8.0) and RDNA3.
# Older NVIDIA GPUs — Turing (RTX 20xx, GTX 16xx, compute 7.5) and Pascal — may see
# instability or NaN outputs with the FA + quantized-KV path. If that happens, set
# OLLAMA_FLASH_ATTENTION=0 above (this also disables KV cache quantization).
# Check your GPU's compute capability:
#   nvidia-smi --query-gpu=name,compute_cap --format=csv
#OLLAMA_KV_CACHE_TYPE=q8_0

# Force a specific AMD GFX driver version, useful for specific models.
# AMD_GFX_VERSION=11.0.0  # gfx1100/1101/1102 (RDNA3), 10.3.0 (RDNA2)
#AMD_GFX_VERSION=11.0.0

# Parallel request slots — Ollama allocates one KV ringbuffer per slot. Default
# upstream is 4. On AMD iGPU / small-VRAM Vulkan setups, set to 1 to shrink peak
# KV allocation and avoid Vulkan per-allocation-cap OOM on large models.
# See docs/gpu-setup.md → "Vulkan on AMD iGPU" for the full tuning guide.
#OLLAMA_NUM_PARALLEL=1

# ── Access & Security ───────────────────────────────────────────────────────
# SSH public key(s) for workspace access. Key-only auth — no password.
#
# Single key (no quotes needed):
#   AUTHORIZED_KEYS=ssh-ed25519 AAAAC3Nza...rest user@host
#
# Multiple keys — wrap in double quotes with real newlines:
#   AUTHORIZED_KEYS="ssh-ed25519 AAAAC3Nza...key1 user@host
#   ssh-ed25519 AAAAC3Nza...key2 user2@host"
#
# Get your key with: cat ~/.ssh/id_ed25519.pub  (or id_rsa.pub / id_ecdsa.pub)
# Add keys later:   docker exec inferhaven-workspace add-ssh-key "ssh-ed25519 ..."
AUTHORIZED_KEYS=

# Password for code-server (VS Code in browser). CHANGE THIS.
CODE_SERVER_PASSWORD=inferhaven

# Restrict all Caddy routes to specific IP ranges (CIDR notation, space-separated).
# Leave empty to allow connections from any IP (default — suitable for local networks).
#
# Localhost access from the host machine is handled automatically: when ALLOWED_IPS
# is set, the Caddy entrypoint detects the Docker bridge gateway IP and adds it to
# the allowlist. You do not need to add anything extra for localhost to keep working.
#
# Example — restrict to a single LAN subnet:
#   ALLOWED_IPS=192.168.1.0/24
#
# Example — restrict to multiple ranges (VPN + LAN):
#   ALLOWED_IPS=10.8.0.0/24 192.168.1.0/24
#
# Security note: ALLOWED_IPS uses the actual TCP source IP (not HTTP headers), so
# it cannot be bypassed by spoofed X-Forwarded-For headers. The auto-added Docker
# gateway IP is private/non-routable; external TCP connections cannot spoof it
# because a 3-way handshake is required and the SYN-ACK would not reach the attacker.
#
# Apply changes: docker compose up -d caddy   (NOT restart — restart keeps old env vars)
ALLOWED_IPS=

# Workspace username
HAVEN_USER=haven

# ── Networking ──────────────────────────────────────────────────────────────
# Domain or IP address for the Caddy reverse proxy.
# TLS mode is auto-detected — no manual configuration needed:
#   localhost                    → plain HTTP
#   192.168.x.x / bare IPv4     → plain HTTP
#   ::1 / bare IPv6              → plain HTTP (auto-bracketed for Caddy)
#   *.lan, *.local, *.home, etc. → Caddy self-signed CA (internal TLS)
#   public domain (e.g. dev.example.com) → Let's Encrypt ACME
DOMAIN=localhost

# Override TLS mode (optional — auto-detection handles most cases).
#   auto     — detect from DOMAIN (default)
#   internal — Caddy self-signed CA; export root cert to trust in your browser:
#              docker cp inferhaven-caddy:/data/caddy/pki/authorities/local/root.crt ./caddy-root.crt
#   acme     — force Let's Encrypt (public domain with reachable port 80 required)
#   off      — plain HTTP, no TLS
#TLS_MODE=auto

# Port mappings (change if you have conflicts)
SSH_PORT=2222
HTTP_PORT=80
HTTPS_PORT=443
OLLAMA_PORT=11434
CODE_SERVER_PORT=8443

# ── System ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── Session persistence ──────────────────────────────────────────────────────
# How many days of tmux session snapshots to keep. With 1-minute auto-saves,
# each day adds ~1440 files (~1-4 MB). Default is 7 days (one week of rollback).
# Restore the most recent snapshot with: haven tmux restore
# TMUX_RESURRECT_RETAIN_DAYS=7

# ── Coding Assistants ────────────────────────────────────────────────────────
# Auto-install coding assistant harnesses on first container start.
# Comma-separated list. Tools install in the background — SSH is not delayed.
# Check progress inside the container: cat ~/.haven/install.log
#
# Available: claudecode, opencode, aider, qwencode, amp, gemini, pi, goose, continue, avante
# Example:   INSTALL_ASSISTANTS=claudecode,opencode
INSTALL_ASSISTANTS=

# Automatically tune models after 'haven pull' for optimal coding assistant use.
# Sets stop tokens, templates, and raises num_ctx to HAVEN_CTX (see below).
# Set to 0 to pull models without tuning (useful when testing raw model behaviour).
HAVEN_AUTO_TUNE=1

# Target context window size for 'haven tune' and auto-tune on pull.
# Defaults to 32768. Lower this on memory-constrained hardware — 16384 works
# with all coding harnesses and fits in ~6 GB RAM for a 7B model.
# haven tune always sets num_ctx to this value, including models that ship with larger defaults.
# HAVEN_CTX=32768

# Goose version to install (aaif-goose fork). Pinned to avoid installing releases
# that break Ollama streaming. Override to test a newer release — check
# https://github.com/aaif-goose/goose/releases for available versions.
# GOOSE_VERSION=v1.27.2

# Starship cross-shell prompt (recommended). Provides a rich, informative prompt
# tailored for AI coding workflows: git status, language versions, background job
# count (surfaces haven pullback workers), and command duration for long-running ops.
# Requires a Nerd Font in your terminal for icons — https://www.nerdfonts.com
# Recommended: JetBrains Mono Nerd Font. Works without icons too (text is always present).
# Set to 0 to keep the default Oh My Zsh robbyrussell theme instead.
INSTALL_STARSHIP=1

# ── Bare-metal tools (P1/P2) ────────────────────────────────────────────────
# mosh — connection-resilient SSH (UDP). Mapped to host UDP 60000-60010 by
# default. Set MOSH_PORTS= (empty) to skip host port mapping (mosh still works
# inside the container; just not from outside).
# MOSH_PORTS=60000-60010

# ── Multi-user (P3) ─────────────────────────────────────────────────────────
# Provision additional users alongside 'haven'. Comma-separated, no spaces.
# Each gets home dir + zsh shell. Optional sudo via HAVEN_EXTRA_USERS_SUDO.
# Per-user SSH keys: AUTHORIZED_KEYS_<USER_UC>=...
# HAVEN_EXTRA_USERS=alice,bob
# HAVEN_EXTRA_USERS_SUDO=alice
# AUTHORIZED_KEYS_ALICE="ssh-ed25519 AAAA... alice@laptop"
# AUTHORIZED_KEYS_BOB="ssh-ed25519 AAAA... bob@laptop"

# ── Dotfiles bootstrap (P2) ─────────────────────────────────────────────────
# On first boot, clones the repo and runs ./install.sh (or ./setup.sh).
# Repeated runs are no-ops (sentinel ~/.haven/.dotfiles-installed).
# DOTFILES_REPO=https://github.com/<you>/dotfiles.git

# API Keys — injected into ~/.inferhaven (chmod 600) at container start.
# Automatically picked up by all installed coding assistants.
# You can also set these after the container is running by editing ~/.inferhaven.
#
# Claude Code, Claw Code, Aider (claude backend):
ANTHROPIC_API_KEY=
# OpenCode (openai backend), Aider (openai backend):
OPENAI_API_KEY=
# Gemini CLI, OpenCode (gemini backend), Aider (gemini backend):
GEMINI_API_KEY=
# Any tool supporting OpenRouter:
OPENROUTER_API_KEY=
# GitHub CLI auth, Copilot:
GITHUB_TOKEN=

# Claude Code behaviour tweaks (optional)
CLAUDE_CODE_DISABLE_TELEMETRY=true

# Default model for OpenCode when ANTHROPIC_API_KEY is set (optional)
# OPENCODE_DEFAULT_MODEL=claude-sonnet-4-6

# ── tmate pair-programming (optional) ───────────────────────────────────────
# Self-hosted tmate server for secure pair-programming (recommended over public
# tmate.io). When TMATE_SERVER_HOST is set, 'haven tmate start' auto-configures
# without an interactive prompt — ideal for team deployments.
# Obtain fingerprints from your tmate server: tmate-server --keys
#
# TMATE_SERVER_HOST=tmate.example.com
# TMATE_SERVER_PORT=22
# TMATE_SERVER_RSA_FP=SHA256:...
# TMATE_SERVER_ED25519_FP=SHA256:...

# ── InferHaven Cloud Agent (optional) ───────────────────────────────────────
# Connect this server to the InferHaven Cloud dashboard for remote management
# (model pulls, SSH keys, live metrics, log streaming).
#
# To enable:
#   1. Create a server in your dashboard at https://app.inferhaven.com
#   2. Copy the three values below from the "Connect" dialog
#   3. Start with the cloud profile: docker compose --profile cloud up -d
#
# The agent initiates ALL connections outbound — no inbound ports are opened.
# Remove these lines at any time to disconnect from the cloud dashboard.
#
# HAVEN_CONTROL_URL=wss://relay.inferhaven.com
# HAVEN_SERVER_ID=
# HAVEN_AGENT_TOKEN=
